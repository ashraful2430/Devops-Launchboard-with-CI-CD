# Copy this file to backend/.env for bare-metal local development.
# In AWS RDS, replace host, user, password, and database with your RDS values.
APP_NAME=DevOps LaunchBoard API
APP_ENV=local
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/launchboard
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SEED_DEMO_DATA=true
